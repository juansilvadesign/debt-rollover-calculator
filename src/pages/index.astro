---
import BaseLayout from '../layouts/BaseLayout.astro';
import { calculateRollover, formatBRL, formatPercent } from '../lib/rollover.mjs';

const defaults = {
  debt: 1000,
  limit: 1500,
  monthlyCetPercent: 6,
};

const initial = calculateRollover(defaults);
const initialFailed = initial.nextFailedMonth;
const maxChartValue = Math.max(defaults.limit, ...initial.rows.map((row) => row.displayDebt));
const chartWidth = (value: number) => `${Math.min(100, Math.max(4, (value / maxChartValue) * 100))}%`;
---

<BaseLayout>
  <main class="app-shell" id="main-content">
    <header class="app-header" aria-label="Cabeçalho">
      <a class="brand" href="/">
        <span class="brand-mark" aria-hidden="true"></span>
        <span>Rolagem</span>
      </a>
      <div class="header-actions">
        <span class="header-meta">Simulação local · CET mensal</span>
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Usar tema escuro" aria-pressed="false" title="Usar tema escuro">
          <svg class="theme-icon theme-icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4.5"></circle>
            <line x1="12" y1="2" x2="12" y2="4"></line>
            <line x1="12" y1="20" x2="12" y2="22"></line>
            <line x1="4.93" y1="4.93" x2="6.34" y2="6.34"></line>
            <line x1="17.66" y1="17.66" x2="19.07" y2="19.07"></line>
            <line x1="2" y1="12" x2="4" y2="12"></line>
            <line x1="20" y1="12" x2="22" y2="12"></line>
            <line x1="4.93" y1="19.07" x2="6.34" y2="17.66"></line>
            <line x1="17.66" y1="6.34" x2="19.07" y2="4.93"></line>
          </svg>
          <svg class="theme-icon theme-icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </div>
    </header>

    <section class="workspace">
      <div class="hero-panel">
        <p class="eyebrow">Calculadora de limite</p>
        <h1>Quanto tempo a rolagem ainda cabe no cartão?</h1>
        <p class="hero-lede">
          O cálculo mostra o último mês viável e o primeiro mês em que a dívida projetada passa do limite disponível.
        </p>

        <div class="hero-result" aria-live="polite">
          <span>Resultado do cenário</span>
          <strong data-result="months">{initial.maxSuccessfulMonths}</strong>
          <small>meses inteiros antes de estourar</small>
        </div>

        <div class="hero-footnote" data-result="insight">
          {
            initialFailed
              ? `Mês ${initialFailed.month} falha com ${formatBRL(initialFailed.displayDebt)}.`
              : 'Nenhum mês falhou no limite de simulação.'
          }
        </div>
      </div>

      <form class="calculator-panel" id="calculator">
        <fieldset>
          <legend>Dados da operação</legend>

          <label class="field" for="debt">
            <span>Dívida inicial <b>obrigatório</b></span>
            <input
              id="debt"
              name="debt"
              aria-describedby="debtHelp"
              inputmode="decimal"
              type="number"
              min="0"
              step="0.01"
              value={defaults.debt}
              required
            />
            <small id="debtHelp">Valor da fatura que precisa ser coberta.</small>
          </label>

          <label class="field" for="limit">
            <span>Limite disponível <b>obrigatório</b></span>
            <input
              id="limit"
              name="limit"
              aria-describedby="limitHelp"
              inputmode="decimal"
              type="number"
              min="0"
              step="0.01"
              value={defaults.limit}
              required
            />
            <small id="limitHelp">Limite livre usado na próxima operação.</small>
          </label>

          <label class="field" for="monthlyCetPercent">
            <span>CET mensal <b>obrigatório</b></span>
            <input
              id="monthlyCetPercent"
              name="monthlyCetPercent"
              aria-describedby="cetHelp"
              inputmode="decimal"
              type="number"
              min="0"
              step="0.01"
              value={defaults.monthlyCetPercent}
              required
            />
            <small id="cetHelp">Use porcentagem mensal. Ex.: 6 para 6%.</small>
          </label>
        </fieldset>

        <div class="form-actions">
          <button type="submit">Recalcular</button>
          <button class="button-secondary" type="button" id="loadExample">Exemplo</button>
        </div>
      </form>
    </section>

    <section class="results-grid" aria-label="Resultado calculado" aria-live="polite">
      <div class="metric-card metric-primary">
        <span>Meses máximos</span>
        <strong data-result="months">{initial.maxSuccessfulMonths}</strong>
        <small>rolagens que ainda passam</small>
      </div>
      <div class="metric-card">
        <span>Dívida final</span>
        <strong data-result="finalDebt">{formatBRL(initial.finalDebt)}</strong>
        <small>último mês que ainda passa</small>
      </div>
      <div class="metric-card">
        <span>Limite sobrante</span>
        <strong data-result="remainingLimit">{formatBRL(initial.remainingLimit)}</strong>
        <small>após a última rolagem possível</small>
      </div>
      <div class="metric-card">
        <span>Primeira falha</span>
        <strong data-result="failedMonth">{initialFailed ? `Mês ${initialFailed.month}` : '—'}</strong>
        <small data-result="failedDebt">{initialFailed ? formatBRL(initialFailed.displayDebt) : 'sem falha'}</small>
      </div>
    </section>

    <section class="status-panel" id="statusPanel" role="status" aria-live="polite" hidden>
      <p id="statusMessage"></p>
    </section>

    <section class="analysis-grid">
      <div class="timeline-panel">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Evolução</p>
            <h2>Mês a mês</h2>
          </div>
          <p>CET: <strong data-result="cet">{formatPercent(defaults.monthlyCetPercent)}</strong></p>
        </div>

        <div class="limit-row">
          <span>Limite disponível</span>
          <strong data-result="limit">{formatBRL(defaults.limit)}</strong>
        </div>

        <div class="timeline" id="timeline">
          {
            initial.rows.map((row) => (
              <div class={`timeline-row is-${row.status}`} aria-label={`Mês ${row.month}: ${formatBRL(row.displayDebt)}, ${row.status === 'success' ? 'passou' : 'estourou'}`}>
                <span class="timeline-month">Mês {row.month}</span>
                <div class="bar-track" aria-hidden="true">
                  <span class="bar-fill" style={`width: ${chartWidth(row.displayDebt)}`}></span>
                </div>
                <strong>{formatBRL(row.displayDebt)}</strong>
                <span class="row-state">{row.status === 'success' ? 'Passou' : 'Estourou'}</span>
              </div>
            ))
          }
        </div>
      </div>

      <div class="table-panel">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Tabela</p>
            <h2>Meses aprovados e reprovado</h2>
          </div>
          <p data-result="formula">Fórmula direta: {initial.directFormulaMonths}</p>
        </div>

        <div class="table-wrap">
          <table>
            <caption>Projeção de rolagem mensal com o primeiro mês reprovado</caption>
            <thead>
              <tr>
                <th>Mês</th>
                <th>Dívida projetada</th>
                <th>Limite sobrante</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="monthRows">
              {
                initial.rows.map((row) => (
                  <tr class={`is-${row.status}`}>
                    <td data-label="Mês">{row.month}</td>
                    <td data-label="Dívida projetada">{formatBRL(row.displayDebt)}</td>
                    <td data-label="Limite sobrante">{formatBRL(row.remainingLimit)}</td>
                    <td data-label="Status">
                      <span>{row.status === 'success' ? 'Passou' : 'Estourou'}</span>
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <footer class="footer-note">
      <p>
        Cálculo educativo, sem orientação financeira. Valores exibidos em centavos truncados para reproduzir a mesa de teste.
      </p>
      <p>Validação: <strong>{formatBRL(initial.finalDebt)} em {initial.maxSuccessfulMonths} meses</strong></p>
    </footer>
  </main>

  <script>
    import { calculateRollover, formatBRL, formatPercent } from '../lib/rollover.mjs';

    const defaults = {
      debt: 1000,
      limit: 1500,
      monthlyCetPercent: 6,
    };

    const form = document.querySelector('#calculator');
    const debtInput = document.querySelector('#debt');
    const limitInput = document.querySelector('#limit');
    const cetInput = document.querySelector('#monthlyCetPercent');
    const loadExampleButton = document.querySelector('#loadExample');
    const statusPanel = document.querySelector('#statusPanel');
    const statusMessage = document.querySelector('#statusMessage');
    const timeline = document.querySelector('#timeline');
    const monthRows = document.querySelector('#monthRows');
    const themeToggle = document.querySelector('#theme-toggle');
    const themeMeta = document.querySelector('meta[name="theme-color"]');

    const resultEls = {
      months: document.querySelectorAll('[data-result="months"]'),
      finalDebt: document.querySelector('[data-result="finalDebt"]'),
      remainingLimit: document.querySelector('[data-result="remainingLimit"]'),
      formula: document.querySelector('[data-result="formula"]'),
      failedMonth: document.querySelector('[data-result="failedMonth"]'),
      failedDebt: document.querySelector('[data-result="failedDebt"]'),
      limit: document.querySelector('[data-result="limit"]'),
      cet: document.querySelector('[data-result="cet"]'),
      insight: document.querySelector('[data-result="insight"]'),
    };

    function valueFrom(input) {
      return Number.parseFloat(input.value.replace(',', '.')) || 0;
    }

    function setText(el, value) {
      if (!el) return;
      if (typeof el.forEach === 'function') {
        el.forEach((item) => {
          item.textContent = value;
        });
        return;
      }
      el.textContent = value;
    }

    function setThemeButtonState() {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      const label = isDark ? 'Usar tema claro' : 'Usar tema escuro';
      themeToggle?.setAttribute('aria-pressed', String(isDark));
      themeToggle?.setAttribute('aria-label', label);
      themeToggle?.setAttribute('title', label);
      themeMeta?.setAttribute('content', isDark ? '#0d100f' : '#f6f8fb');
    }

    function toggleTheme() {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      const next = isDark ? 'light' : 'dark';

      if (next === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.removeAttribute('data-theme');
      }

      try {
        localStorage.setItem('site-theme', next);
      } catch {
        // Theme still changes for the current session when storage is unavailable.
      }

      setThemeButtonState();
    }

    function showStatus(message) {
      if (!statusPanel || !statusMessage) return;
      statusMessage.textContent = message;
      statusPanel.hidden = false;
    }

    function hideStatus() {
      if (statusPanel) statusPanel.hidden = true;
      if (statusMessage) statusMessage.textContent = '';
    }

    function renderEmptyState(result) {
      showStatus(result.message);
      setText(resultEls.months, '0');
      setText(resultEls.finalDebt, '—');
      setText(resultEls.remainingLimit, '—');
      setText(resultEls.formula, '—');
      setText(resultEls.failedMonth, '—');
      setText(resultEls.failedDebt, 'sem cálculo');
      setText(resultEls.limit, formatBRL(result.input.limit));
      setText(resultEls.cet, formatPercent(result.input.monthlyCetPercent));
      setText(resultEls.insight, result.message);
      if (timeline) timeline.innerHTML = '';
      if (monthRows) monthRows.innerHTML = '';
    }

    function renderTimeline(rows, limit) {
      if (!timeline) return;
      const maxValue = Math.max(limit, ...rows.map((row) => row.displayDebt));
      timeline.innerHTML = rows
        .map((row) => {
          const width = Math.min(100, Math.max(4, (row.displayDebt / maxValue) * 100));
          return `
            <div class="timeline-row is-${row.status}" aria-label="Mês ${row.month}: ${formatBRL(row.displayDebt)}, ${row.status === 'success' ? 'passou' : 'estourou'}">
              <span class="timeline-month">Mês ${row.month}</span>
              <div class="bar-track" aria-hidden="true">
                <span class="bar-fill" style="width: ${width}%"></span>
              </div>
              <strong>${formatBRL(row.displayDebt)}</strong>
              <span class="row-state">${row.status === 'success' ? 'Passou' : 'Estourou'}</span>
            </div>
          `;
        })
        .join('');
    }

    function renderTable(rows) {
      if (!monthRows) return;
      monthRows.innerHTML = rows
        .map((row) => `
          <tr class="is-${row.status}">
            <td data-label="Mês">${row.month}</td>
            <td data-label="Dívida projetada">${formatBRL(row.displayDebt)}</td>
            <td data-label="Limite sobrante">${formatBRL(row.remainingLimit)}</td>
            <td data-label="Status"><span>${row.status === 'success' ? 'Passou' : 'Estourou'}</span></td>
          </tr>
        `)
        .join('');
    }

    function renderInsight(result) {
      const failed = result.nextFailedMonth;
      if (!failed) {
        setText(resultEls.failedMonth, '—');
        setText(resultEls.failedDebt, 'sem falha');
        setText(resultEls.insight, 'Nenhum mês falhou no limite de simulação.');
        return;
      }

      setText(resultEls.failedMonth, `Mês ${failed.month}`);
      setText(resultEls.failedDebt, formatBRL(failed.displayDebt));
      setText(
        resultEls.insight,
        `Mês ${failed.month} estoura o limite em ${formatBRL(Math.abs(failed.remainingLimit))}.`
      );
    }

    function render() {
      const input = {
        debt: valueFrom(debtInput),
        limit: valueFrom(limitInput),
        monthlyCetPercent: valueFrom(cetInput),
      };

      const result = calculateRollover(input);
      if (!result.ok) {
        renderEmptyState(result);
        return;
      }

      hideStatus();
      setText(resultEls.months, String(result.maxSuccessfulMonths));
      setText(resultEls.finalDebt, formatBRL(result.finalDebt));
      setText(resultEls.remainingLimit, formatBRL(result.remainingLimit));
      setText(resultEls.formula, `Fórmula direta: ${result.directFormulaMonths}`);
      setText(resultEls.limit, formatBRL(input.limit));
      setText(resultEls.cet, formatPercent(input.monthlyCetPercent));
      renderInsight(result);
      renderTimeline(result.rows, input.limit);
      renderTable(result.rows);
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      render();
    });

    [debtInput, limitInput, cetInput].forEach((input) => {
      input?.addEventListener('input', render);
    });

    loadExampleButton?.addEventListener('click', () => {
      debtInput.value = String(defaults.debt);
      limitInput.value = String(defaults.limit);
      cetInput.value = String(defaults.monthlyCetPercent);
      render();
    });

    themeToggle?.addEventListener('click', toggleTheme);
    setThemeButtonState();
  </script>
</BaseLayout>
